# ═══════════════════════════════════════════════════════════════════
# MOVE INSIGHTS · Variáveis de ambiente
# Copie para .env e preencha com seus valores
# ═══════════════════════════════════════════════════════════════════

# ── BANCO DE DADOS ──────────────────────────────────────────────────
DATABASE_URL=postgresql://movedev:movesecret123@localhost:5432/move_insights

# ── REDIS ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── META API ────────────────────────────────────────────────────────
META_SYSTEM_USER_TOKEN=seu_token_aqui
META_BUSINESS_ID=seu_business_id_aqui
META_API_VERSION=v25.0

# ── CLAUDE API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=seu_api_key_aqui
CLAUDE_MODEL=claude-sonnet-4-6

# ── WHATSAPP ────────────────────────────────────────────────────────
WHATSAPP_SESSION_PATH=./whatsapp-session
WHATSAPP_HEADLESS=true

# ── AUTENTICAÇÃO ────────────────────────────────────────────────────
SESSION_SECRET=seu_session_secret_aqui_min_32_caracteres

# ── SEED DO ADMIN ───────────────────────────────────────────────────
SEED_ADMIN_NOME=Lucas Macena
SEED_ADMIN_EMAIL=luan@movebusiness.com.br
SEED_ADMIN_PASSWORD=mudar-no-primeiro-login

# ── URLs (CORS + COOKIES) ───────────────────────────────────────────
ADMIN_URL=http://localhost:5173
CLIENTE_URL=http://localhost:5174
COOKIE_DOMAIN=localhost

# ── CRIPTOGRAFIA ────────────────────────────────────────────────────
APP_ENCRYPTION_KEY=gerar-32-bytes-base64-aqui

# ── SERVIDOR ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug
