# ═══════════════════════════════════════════════════════════════════
#  TEMPLATE — copie para .env e preencha com valores reais
#  Este arquivo (.env.example) PODE ir pro GitHub. O .env NÃO.
# ═══════════════════════════════════════════════════════════════════

# ── Mercado Pago ──────────────────────────────────────────────────
# Pegue em: mercadopago.com.br/developers → Suas integrações →
# sua app → Credenciais de produção → "Access Token"
MP_ACCESS_TOKEN=APP_USR-seu-access-token-aqui

# Pegue em: Suas integrações → sua app → Webhooks →
# configure a URL e copie a "Chave secreta"
MP_WEBHOOK_SECRET=seu-webhook-secret-aqui

# ── Servidor ──────────────────────────────────────────────────────
BASE_URL=https://seu-dominio.com

# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=gere-uma-string-aleatoria-longa

# ── Google OAuth (opcional — pro botão "Continuar com Google") ─────────
# Pegue em: console.cloud.google.com → APIs & Services → Credentials →
# Create Credentials → OAuth Client ID → Web Application
GOOGLE_CLIENT_ID=seu-id.apps.googleusercontent.com

PORT=3000
