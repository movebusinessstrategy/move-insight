{
  "name": "move-insights-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "node --loader ts-node/esm src/db/migrate.ts",
