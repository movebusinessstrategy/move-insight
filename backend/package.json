    "meta:check-token": "node --loader ts-node/esm src/scripts/meta-check.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.12.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.4.8",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "node-cron": "^3.0.3",
    "pino": "^8.16.2",
    "pino-http": "^8.5.0",
    "postgres": "^3.4.4",
    "puppeteer": "^21.11.0",
    "qrcode-terminal": "^0.12.0",
    "redis": "^4.6.11",
    "whatsapp-web.js": "^1.34.6",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode-terminal": "^0.12.2",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
